{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tsconfig/node22",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": "./src",
    "outDir": "./lib",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["./src"]
}
